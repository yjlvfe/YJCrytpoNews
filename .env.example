# YJCrytpoNews — Secrets Configuration
# Copy this file to .env and fill in your values

# --- Primary AI Provider ---
# OpenRouter key (openrouter.ai/keys) or your preferred provider
AI_API_KEY=your-openrouter-api-key

# --- Fallback AI Provider ---
# Groq API key (free at console.groq.com)
AI_FALLBACK_KEY=your-groq-api-key

# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=your-telegram-bot-token

# --- Optional Fallback AI Keys ---
# Uncomment and fill in to add redundancy

# Mistral API key (console.mistral.ai)
# AI_API_KEY_2=your-mistral-api-key

# Fireworks AI key (fireworks.ai)
# AI_API_KEY_3=your-fireworks-api-key

# NVIDIA NIM key (build.nvidia.com)
# AI_FALLBACK_KEY_2=your-nvidia-api-key

# SambaNova key (cloud.sambanova.ai)
# AI_FALLBACK_KEY_3=your-sambanova-api-key

# Cerebras key (cloud.cerebras.ai)
# AI_FALLBACK_KEY_4=your-cerebras-api-key

# Ollama Cloud key (ollama.com/settings/keys)
# AI_FALLBACK_KEY_5=your-ollama-api-key

# AI21 Labs key (studio.ai21.com)
# AI_FALLBACK_KEY_6=your-ai21-api-key
